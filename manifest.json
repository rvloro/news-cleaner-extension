{
  "manifest_version": 3,
  "name": "News Cleaner",
  "version": "4.0",
  "description": "Une extension moderne pour purger vos sites d’actu préférés.",

  "browser_specific_settings": {
    "gecko": {
      "id": "news-cleaner@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "*://*.lefigaro.fr/*",
    "*://*.lemonde.fr/*",
    "*://*.liberation.fr/*",
    "*://*.leparisien.fr/*",
    "*://*.bfmtv.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.lefigaro.fr/*",
        "*://*.lemonde.fr/*",
        "*://*.liberation.fr/*",
        "*://*.leparisien.fr/*",
        "*://*.bfmtv.com/*"
      ],
      "js": ["sites.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}